{
  "version": "1",
  "enabled-engines": ["flink", "postgres", "kafka", "iceberg", "duckdb", "vertx"],
  "script": {
    "main": "test.sqrl",
    "config": {
      "environment": "test",
      "ecommerce-test-data": "dev"
    }
  },
  "engines": {
    "flink": {
      "config": {
        "execution.runtime-mode": "STREAMING",
        "table.exec.source.idle-timeout": "10 s"
      }
    }
  },
  "compiler": {
    "predicate-pushdown-rules": "LIMITED_RULES"
  },
  "test-runner": {
    "delay-sec": -1,
    "required-checkpoints": 1
  }
}
